# ================================
# PROVIDER WHATSAPP
# ================================
WHATSAPP_PROVIDER=gupshup

# ================================
# GUPSHUP (production recommandé)
# ================================
GUPSHUP_APP_ID=
GUPSHUP_API_KEY=
GUPSHUP_WEBHOOK_TOKEN=
# IPs autorisées Gupshup (séparées par virgule) - Optionnel mais recommandé
# Contacter devsupport@gupshup.io pour obtenir les IPs officielles
GUPSHUP_ALLOWED_IPS=

# ================================
# TWILIO (développement)
# ================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=

# ================================
# META CLOUD API (production alternative)
# ================================
META_PHONE_ID=
META_TOKEN=
META_VERIFY_TOKEN=
META_APP_SECRET=

# ================================
# SUPABASE
# ================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ================================
# CLAUDE API
# ================================
ANTHROPIC_API_KEY=

# ================================
# OPENAI WHISPER
# ================================
OPENAI_API_KEY=

# ================================
# APP
# ================================
PORT=3000
NODE_ENV=development

# ================================
# SUPPORT
# ================================
